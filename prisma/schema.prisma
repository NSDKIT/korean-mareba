// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")  // Supabase接続プーリング対応
}

model User {
  id                    String         @id @default(cuid())
  email                 String         @unique
  displayName           String?
  role                  Role           @default(USER)
  level                 Int            @default(1) // 1〜5
  plan                  Plan           @default(FREE)
  stripeCustomerId      String?        @unique
  stripeSubscriptionId  String?        @unique
  placementDone         Boolean        @default(false)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  conversations         Conversation[]
  usageLogs             UsageLog[]
  savedPhrases          SavedPhrase[]
  badges                UserBadge[]

  @@index([email])
  @@index([plan])
  @@index([level])
  @@index([createdAt])
}

model Conversation {
  id         String    @id @default(cuid())
  userId     String
  scenarioId String
  messages   Json      // Message[]型
  score      Int?      // 0〜100
  feedback   Json?     // FeedbackReport型
  duration   Int?      // 会話時間（秒）
  xpEarned   Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([scenarioId])
  @@index([createdAt])
  @@index([score])
}

model UsageLog {
  id        String   @id @default(cuid())
  userId    String
  date      String   // YYYY-MM-DD
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model SavedPhrase {
  id        String   @id @default(cuid())
  userId    String
  ko        String   // 韓国語
  ruby      String   // 読み仮名（ハングル読み）
  ja        String   // 日本語訳
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Badge {
  id          String      @id @default(cuid())
  name        String      @unique
  description String
  iconUrl     String
  condition   Json        // 取得条件の定義
  userBadges  UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
}

enum Plan {
  FREE
  STANDARD
  PREMIUM
}

enum Role {
  USER
  ADMIN
}
